# Production environment template
# Copy this to `.env` on the server and fill in real values.

CI_ENVIRONMENT = production

app.baseURL = 'https://your-domain.example/'

database.default.hostname = your-db-host
database.default.database = your-db-name
database.default.username = your-db-user
database.default.password = your-db-password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

encryption.key = your-32-byte-or-longer-secret-key

# Set this only before the very first production migration/bootstrap.
# Rotate or remove it immediately after first admin login.
auth.bootstrapAdminPassword = change-me-before-first-migrate

# Required for admin forgot-password recovery flow.
auth.adminRecoveryKey = change-me-admin-recovery-key

# Mobile API bearer token lifetime in hours.
auth.apiTokenTtlHours = 168
